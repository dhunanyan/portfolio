# Resend server-side API key (never expose in client code)
RESEND_API_KEY="re_xxxxxxxxx"

# Must use a sender from a verified domain in Resend
# Example: Portfolio Contact <contact@yourdomain.com>
CONTACT_FROM_EMAIL="Portfolio Contact <contact@yourdomain.com>"

# Where contact form emails should arrive
CONTACT_TO_EMAIL="you@yourdomain.com"
